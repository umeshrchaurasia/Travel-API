    <title>IndusInd Travel Insurance - Certificate</title>

    <style>
        @page {
            margin: 5px 6px 5px 5px;
            /* top, right, bottom, left */
        }

        /* Footer positioning */
        .footer {
            position: absolute;
            bottom: 2px;
            left: 2px;
            right: 2px;
            font-size: 9px;
            line-height: 1.4;
            padding: 2px;
            color: #000;
            width: calc(100% - 4px);
            text-align: left;
        }



        .withfooter {
            position: relative;
            page-break-after: always;
            min-height: 100vh;
        }

        .footernew {
            position: absolute;
            bottom: 5px;
            left: 2px;
            right: 2px;
            border-bottom: solid 5px #3763af;
            padding: 0px;
            width: calc(100% - 4px);
        }


        /* Page container for relative positioning */
        .page-container {
            position: relative;
            min-height: calc(100vh - 120px);
            /* Reserve space for footer */
            padding-bottom: 120px;
            /* Ensure content doesn't overlap footer */
        }

        .page-container-footernew {
            position: relative;
            min-height: calc(100vh - 150px);
            /* Reserve more space for footernew which is larger */
            padding-bottom: 150px;
            /* Ensure content doesn't overlap footernew */
        }

        table {
            page-break-inside: avoid;
        }
    </style>
</head>

