            </div>



            <!-- OVERLAPPING BLUE CARD SECTION -->



            <!-- DISCLAIMER -->

            <div
                style="padding: 5px 20px;  font-size: 9px; color: #777; text-align: justify; border-top: 1px solid #eee;">

                <strong>Disclaimer:</strong> Interstellar Services Private Limited acts solely as a facilitator. The

                Company

