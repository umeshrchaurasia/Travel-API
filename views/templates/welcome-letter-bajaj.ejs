                <!-- FOOTER WITH BACKGROUND IMAGE -->

                <div
                    style="width: 100%; height: 150px;background: url('<%= policy.wel_footerbottomBase64 %>') no-repeat right bottom; background-size: contain; position: relative;">

                    <div style="padding: 5px 20px; position: absolute; bottom: 0; left: 0;">

